# Redis (en Render se configura automaticamente desde el servicio)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Coinbase - ruta al archivo JSON de credenciales CDP
# En Render: /etc/secrets/coinbase_api_key.json (Secret File)
# En local: ruta absoluta a tu archivo de credenciales
COINBASE_CREDENTIALS_PATH=/etc/secrets/coinbase_api_key.json

# Ejecucion de ordenes
EXECUTION_ENABLED=true
EXECUTION_DRY_RUN=true        # true = simula sin enviar ordenes reales
PILOT_ORDER_NOTIONAL_USD=25

# Paper trading (opcional)
PAPER_TRADING_ENABLED=false
PAPER_INITIAL_CASH=10000

# Activos (opcional - si no se define usa los defaults del codigo)
# PRODUCTS_CSV=BTC-USDT,ETH-USDT
# OBSERVED_BASES_CSV=BTC,ETH,SOL,XRP,ADA

# Modelos (opcional - si no se define usa los defaults del codigo)
# MODEL_REGISTRY_ROOT=models/multi_asset_live_v2
